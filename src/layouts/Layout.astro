---
import "@/index.css";

interface Props {
  title: string;
  description?: string;
  ogUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = "Senior Full Stack Developer specializing in React, TypeScript, Node.js, and Web3. Currently exploring Next.js 16 and Smart Contracts. Available for full-time & contract opportunities.",
  ogUrl = "https://jillowoche.dev",
  ogImage = "https://opengraph.b-cdn.net/production/images/765d9b15-b06d-41b9-a1cb-69bef5f02a66.jpg?token=UliMuvZmVUbNeWtX10YxzpoPXUvZLmIYcvEwdRsxsoU&height=800&width=1200&expires=33299291148",
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- DNS prefetch / preconnect -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    <link rel="dns-prefetch" href="//vercel.live" />
    <link rel="dns-prefetch" href="//vitals.vercel-analytics.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />

    <!-- Hero image preload (LCP) -->
    <link
      rel="preload"
      as="image"
      href="https://res.cloudinary.com/dsuhsqcb2/image/upload/f_auto,q_auto,w_300/v1763295450/sneakerhead985NoBg_wzya7p.webp"
      type="image/webp"
      media="(max-width: 768px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="https://res.cloudinary.com/dsuhsqcb2/image/upload/f_auto,q_auto,w_512/v1763295450/sneakerhead985NoBg_wzya7p.webp"
      type="image/webp"
      media="(min-width: 769px)"
      fetchpriority="high"
    />

    <!-- Font -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Exo:wght@100;200;300;400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Exo:wght@100;200;300;400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Exo:wght@100;200;300;400;500;600&display=swap"
      />
    </noscript>

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="jillowoche.dev" />
    <meta property="twitter:url" content={ogUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data (Person) — home page only -->
    {
      currentPath === "/" && (
        <script type="application/ld+json">
          {JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Person",
            name: "Jillo Woche",
            url: "https://jillowoche.dev",
            jobTitle: "Full Stack Developer & Web3 Engineer",
            description:
              "Senior Full Stack Developer specializing in React, TypeScript, Node.js, and Web3 technologies.",
            image: "https://jillowoche.dev/me.webp",
            email: "jayloabdullahi@gmail.com",
            sameAs: [
              "https://github.com/jillo-abdullahi",
              "https://linkedin.com/in/jilloabdullahi/",
              "https://x.com/shrewd_turtle",
              "https://stackoverflow.com/users/7300926/jillo-abdullahi",
              "https://www.instagram.com/jillo_woche/",
            ],
            knowsAbout: [
              "React",
              "TypeScript",
              "Node.js",
              "JavaScript",
              "Web3",
              "Blockchain",
              "Next.js",
              "Smart Contracts",
              "Full Stack Development",
            ],
            alumniOf: {
              "@type": "EducationalOrganization",
              name: "Jomo Kenyatta University of Agriculture and Technology",
            },
            workLocation: { "@type": "Place", name: "Remote" },
          })}
        </script>
      )
    }

    <!-- Theme / PWA meta -->
    <meta name="theme-color" content="#e7a11a" />
    <meta name="msapplication-TileColor" content="#e7a11a" />
    <meta name="msapplication-navbutton-color" content="#e7a11a" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Critical inline CSS -->
    <style>
      body {
        font-family: "Exo", -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, "Helvetica Neue", Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-color: #0f0f0f;
        margin: 0;
        padding: 0;
      }
      @keyframes slideInFromTop {
        from {
          opacity: 0;
          transform: translateY(-100%);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .slideInFromTop {
        animation: slideInFromTop 0.5s;
      }
      :root {
        --color-orange: #e7a11a;
        --color-orange-dark: #d19115;
        --color-blue-dark: #272f37;
      }
    </style>

    <!-- Font loading optimisation -->
    <script>
      if ("fonts" in document) {
        document.fonts.load("400 1em Exo").then(function () {
          document.documentElement.classList.add("fonts-loaded");
        });
      } else {
        document.documentElement.classList.add("fonts-loaded");
      }
    </script>

    <!-- Theme anti-flicker: apply saved color + dark/light before first paint -->
    <script is:inline>
      (function () {
        try {
          var THEME_COLORS = {
            coral: {
              primary: "#ff6f3c",
              primaryHover: "#ff5722",
              primaryLight: "rgba(255, 111, 60, 0.1)",
              primaryBorder: "rgba(255, 111, 60, 0.4)",
            },
            orange: {
              primary: "#c2410c",
              primaryHover: "#9a3412",
              primaryLight: "rgba(194, 65, 12, 0.1)",
              primaryBorder: "rgba(194, 65, 12, 0.4)",
            },
            blue: {
              primary: "#3b82f6",
              primaryHover: "#2563eb",
              primaryLight: "rgba(59, 130, 246, 0.1)",
              primaryBorder: "rgba(59, 130, 246, 0.4)",
            },
            purple: {
              primary: "#a855f7",
              primaryHover: "#9333ea",
              primaryLight: "rgba(168, 85, 247, 0.1)",
              primaryBorder: "rgba(168, 85, 247, 0.4)",
            },
            emerald: {
              primary: "#2ecc40",
              primaryHover: "#27ae60",
              primaryLight: "rgba(46, 204, 64, 0.1)",
              primaryBorder: "rgba(46, 204, 64, 0.4)",
            },
            slate: {
              primary: "#64748b",
              primaryHover: "#475569",
              primaryLight: "rgba(100, 116, 139, 0.1)",
              primaryBorder: "rgba(100, 116, 139, 0.4)",
            },
            pesto: {
              primary: "#A89A04",
              primaryHover: "#8a7e03",
              primaryLight: "rgba(168, 154, 4, 0.1)",
              primaryBorder: "rgba(168, 154, 4, 0.4)",
            },
            teal: {
              primary: "#0d9488",
              primaryHover: "#0f766e",
              primaryLight: "rgba(13, 148, 136, 0.1)",
              primaryBorder: "rgba(13, 148, 136, 0.4)",
            },
          };
          var root = document.documentElement;
          var themeColor = localStorage.getItem("theme-color") || "blue";
          var colors = THEME_COLORS[themeColor] || THEME_COLORS.blue;

          root.style.setProperty("--color-primary", colors.primary);
          root.style.setProperty(
            "--color-primary-hover",
            colors.primaryHover
          );
          root.style.setProperty(
            "--color-primary-light",
            colors.primaryLight
          );
          root.style.setProperty(
            "--color-primary-border",
            colors.primaryBorder
          );

          var metaTheme = document.querySelector('meta[name="theme-color"]');
          var metaTile = document.querySelector(
            'meta[name="msapplication-TileColor"]'
          );
          var metaNav = document.querySelector(
            'meta[name="msapplication-navbutton-color"]'
          );
          if (metaTheme) metaTheme.setAttribute("content", colors.primary);
          if (metaTile) metaTile.setAttribute("content", colors.primary);
          if (metaNav) metaNav.setAttribute("content", colors.primary);

          var themeMode = localStorage.getItem("theme-mode");
          if (themeMode === "light") {
            root.classList.remove("dark");
          } else {
            root.classList.add("dark");
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
